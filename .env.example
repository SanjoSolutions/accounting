DATABASE_URL=file:./accounting.db

AUTH_MODE=none
# BETTER_AUTH_URL=http://localhost:3000
# BETTER_AUTH_SECRET=
# BETTER_AUTH_DISABLE_SIGN_UP=false

# ELSTER ERiC 44 / E-Bilanz 6.9. Build tools/eric-bridge first and point to
# its executable. Obtain your own manufacturer ID in the ELSTER developer area.
# Never store the certificate PIN here; it is entered only for an explicit send.
# ERIC_BRIDGE_PATH=C:\absolute\path\to\EricBridge.exe
# ERIC_RUNTIME_DIR=C:\absolute\path\to\ERiC-44.2.4.0\Windows-x86_64\dll
# ERIC_HERSTELLER_ID=
# ERIC_CERTIFICATE_PATH=C:\absolute\path\to\certificate.pfx
# ERIC_TESTMERKER=700000004

# Apache OpenDAL document storage. The default stores files in ./storage.
DOCUMENT_STORAGE_DRIVER=fs
DOCUMENT_STORAGE_ROOT=./storage
DOCUMENT_STORAGE_REGION=local
DOCUMENT_STORAGE_MAX_UPLOAD_BYTES=20971520

# Compliance integrity and backup encryption. Generate independent random keys;
# retain old key IDs in the JSON keyring for the full backup retention period.
# AUDIT_INTEGRITY_KEYS={"audit-2026":"AT_LEAST_32_RANDOM_CHARACTERS"}
# AUDIT_INTEGRITY_KEY_ID=audit-2026
# A single-key deployment may instead use AUDIT_INTEGRITY_SECRET.
# AUDIT_INTEGRITY_SECRET=
# COMPLIANCE_BACKUP_KEYS_BASE64={"key-2026":"BASE64_ENCODED_32_BYTE_KEY"}
# A single-key deployment may instead set both values below.
# COMPLIANCE_BACKUP_KEY_ID=key-2026
# COMPLIANCE_BACKUP_KEY_BASE64=

# S3 / S3-compatible storage
# DOCUMENT_STORAGE_DRIVER=s3
# DOCUMENT_STORAGE_BUCKET=
# DOCUMENT_STORAGE_REGION=
# DOCUMENT_STORAGE_ENDPOINT=
# DOCUMENT_STORAGE_ACCESS_KEY_ID=
# DOCUMENT_STORAGE_SECRET_ACCESS_KEY=

# Google Cloud Storage
# DOCUMENT_STORAGE_DRIVER=gcs
# DOCUMENT_STORAGE_BUCKET=
# DOCUMENT_STORAGE_CREDENTIAL_PATH=

# Azure Blob Storage
# DOCUMENT_STORAGE_DRIVER=azblob
# DOCUMENT_STORAGE_CONTAINER=
# DOCUMENT_STORAGE_ENDPOINT=https://ACCOUNT.blob.core.windows.net
# DOCUMENT_STORAGE_ACCOUNT_NAME=
# DOCUMENT_STORAGE_ACCOUNT_KEY=

# Additional OpenDAL options can be supplied as a JSON object. They override
# the named options above.
# DOCUMENT_STORAGE_OPTIONS={"root":"accounting"}

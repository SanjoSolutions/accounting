{
  "name": "@accounting/app",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "prisma migrate deploy && prisma generate && next dev",
    "start": "next start",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "eric:build": "dotnet publish tools/eric-bridge/EricBridge.csproj -c Release -o .eric/bridge",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "dev:e2e": "node e2e/prepare-database.mjs && prisma db push && prisma generate && next dev --hostname 127.0.0.1 --port 3100",
    "coverage": "vitest run --coverage --reporter html",
    "coverage:agent": "vitest run --coverage --reporter=minimal"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.23",
    "@google-cloud/documentai": "^3.2.1",
    "@google-cloud/vision": "^2.4.2",
    "@napi-rs/canvas": "1.0.2",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sanjo/array": "^1.0.6",
    "@sanjo/identity": "^2.0.3",
    "better-auth": "^1.6.23",
    "bootstrap": "^5.1.3",
    "bootstrap-icons": "^1.7.2",
    "csv-parse": "^7.0.1",
    "dotenv": "^17.4.2",
    "fflate": "^0.8.3",
    "lodash": "^4.17.21",
    "next": "^16.2.10",
    "next-intl": "^4.13.2",
    "opendal": "^0.49.5",
    "pdfjs-dist": "6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "saxes": "5.0.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/lodash": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "4.1.10",
    "prisma": "^7.8.0",
    "sass": "^1.101.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.16.0+sha512.b767e9a98fc87aec0f42daefcd0e84941c2cdb45d73c4e1e68860fb2bdfdbe032ab592105479e5e05c237f740c8a5ffdbbb52385797ddc2296745a1bbb883e8d",
  "engines": {
    "node": ">=22.13.0"
  }
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AccountRecord {
  id        String   @id
  ownerId   String?  @unique
  payload   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyProfileVersion {
  id            String    @id @default(cuid())
  ownerId       String
  effectiveFrom DateTime
  effectiveTo   DateTime?
  payload       String
  createdBy     String
  reason        String
  createdAt     DateTime  @default(now())

  @@unique([ownerId, effectiveFrom])
  @@index([ownerId, effectiveFrom, effectiveTo])
}

model CompanyProfileAddressConfirmation {
  id String @id @default(cuid())
  ownerId String
  profileVersionId String @unique
  payload String
  createdBy String
  reason String
  createdAt DateTime @default(now())
  @@index([ownerId, createdAt])
}

model AuditEvent {
  id            String   @id
  ownerId       String
  actorId       String
  occurredAt    DateTime
  action        String
  reason        String
  objectType    String
  objectId      String
  semanticDelta String
  previousHash String?
  hash String
  integrityKeyId String @default("default")
  createdAt DateTime @default(now())
  @@unique([ownerId, hash])
  @@index([ownerId, occurredAt])
}

model AuditHead {
  ownerId String @id
  headHash String?
  legacyHeadHash String?
  legacyEventCount Int @default(0)
  version Int @default(0)
  updatedAt DateTime @updatedAt
}

model BackupManifest {
  id              String    @id @default(cuid())
  ownerId         String
  createdAt       DateTime  @default(now())
  databaseHash    String
  objectStoreHash String
  encryptionKeyId String
  storageRegion   String
  recoveryPointAt DateTime
  verifiedAt DateTime?
  restoredAt DateTime?
  manifest String
  payloadStorageKey String?
  status String @default("CREATED")
  @@index([ownerId, createdAt])
}

model CompliancePolicy {
  ownerId String @id
  allowedStorageRegions String
  operatorIds String
  recoveryPointObjectiveMinutes Int
  recoveryTimeObjectiveMinutes Int
  backupKeyId String
  updatedAt DateTime @updatedAt
}

model DocumentRecord {
  id                String                      @id
  payload           String
  ownerId           String?
  attachments       JournalDocumentAttachment[]
  structuredInvoice StructuredInvoice?

  @@index([ownerId])
}

model DocumentStorageClaim {
  id             String   @id
  importId       String
  documentId     String
  ownerId        String
  storageKey     String
  createdStorage Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@unique([importId, documentId])
  @@index([documentId])
  @@index([createdAt])
}

model RetainedArtifact {
  id             String    @id @default(cuid())
  ownerId        String
  objectType     String
  objectId       String
  version        Int
  retentionClass String
  contentHash    String
  provenance     String
  storageKey     String?
  periodEndsAt   DateTime
  retainUntil    DateTime
  legalHoldUntil DateTime?
  legalHoldReason String?
  lastFixityAt DateTime?
  disposedAt DateTime?
  disposalRequestedAt DateTime?
  storageDeletedAt DateTime?
  createdAt DateTime @default(now())
  @@unique([ownerId, objectType, objectId, version])
  @@index([ownerId, retainUntil, legalHoldUntil])
}

model FixityCheck {
  id           String   @id @default(cuid())
  ownerId      String
  artifactId   String
  expectedHash String
  actualHash   String?
  status       String
  readable     Boolean
  checkedAt    DateTime @default(now())

  @@index([ownerId, artifactId, checkedAt])
}

model BookingRecordEntry {
  id      String @id
  payload String
}

model LedgerAccount {
  id              String        @id @default(cuid())
  ownerId         String
  number          Int
  name            String
  category        String
  eBilanzPosition String?
  active          Boolean       @default(true)
  journalLines    JournalLine[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([ownerId, number])
}

model AccountMappingVersion {
  id              String    @id @default(cuid())
  ownerId         String
  chartId         String
  accountNumber   Int
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  accountName     String
  accountType     String
  normalBalance   String
  hgbPosition     String
  eBilanzPosition String
  vatCode         String?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@unique([ownerId, chartId, accountNumber, effectiveFrom])
  @@index([ownerId, effectiveFrom, effectiveTo])
}

model LedgerProfile {
  ownerId          String  @id
  chart            String
  consultantNumber String?
  clientNumber     String?
  accountLength    Int?
}

model FiscalYear {
  id                  String               @id @default(cuid())
  ownerId             String
  year                Int
  label               String?
  startsAt            DateTime
  endsAt              DateTime
  status              String               @default("OPEN")
  lockedAt            DateTime?
  closingSnapshot     String?
  journalEntries      JournalEntry[]
  eBalanceSubmissions EBalanceSubmission[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([ownerId, year])
  @@unique([ownerId, startsAt, endsAt])
  @@index([ownerId, startsAt, endsAt])
}

model EBalanceSubmission {
  id                String     @id @default(cuid())
  ownerId           String
  year              Int
  fiscalYearId      String
  fiscalYear        FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Restrict)
  kind              String
  status            String
  idempotencyKey    String
  payloadHash       String
  requestHash       String
  requestXml        String
  ericCode          Int?
  ericMessage       String?
  resultXml         String?
  serverResponseXml String?
  createdAt         DateTime   @default(now())

  @@unique([ownerId, idempotencyKey])
  @@index([ownerId, year, createdAt])
}

model JournalEntry {
  id              String                      @id @default(cuid())
  sequenceNumber  Int
  bookingDate     DateTime
  documentNumber  String
  description     String
  source          String                      @default("MANUAL")
  state           String                      @default("POSTED")
  entryDate       DateTime?                   @default(now())
  lateReason      String?
  reversalOfId    String?                     @unique
  replacementOfId String?                     @unique
  externalKey     String?                     @unique
  fiscalYearId    String
  fiscalYear      FiscalYear                  @relation(fields: [fiscalYearId], references: [id], onDelete: Restrict)
  lines           JournalLine[]
  documents       JournalDocumentAttachment[]
  createdAt       DateTime                    @default(now())

  @@unique([fiscalYearId, sequenceNumber])
  @@unique([fiscalYearId, documentNumber])
  @@index([bookingDate])
}

model JournalDraft {
  id String @id @default(cuid())
  ownerId String
  fiscalYearId String
  payload String
  version Int @default(1)
  status String @default("DRAFT")
  postedEntryId String?
  createdBy String
  updatedBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([ownerId, fiscalYearId, status])
}

model PeriodReopenRequest {
  id           String    @id @default(cuid())
  ownerId      String
  fiscalYearId String
  requestedBy String
  closeGenerationAt DateTime?
  approvedBy String?
  reason String
  status String
  requestedAt DateTime @default(now())
  decidedAt DateTime?
  @@index([ownerId, fiscalYearId, requestedAt])
}

model FilingAmendment {
  id String @id @default(cuid())
  ownerId String
  kind String
  originalObjectId String
  requestPayload String
  responsePayload String?
  receiptPayload String?
  reason String
  status String @default("DRAFT")
  createdBy String
  createdAt DateTime @default(now())
  @@index([ownerId, kind, originalObjectId, createdAt])
}

model JournalDocumentAttachment {
  journalEntryId String
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  documentId     String
  document       DocumentRecord @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@id([journalEntryId, documentId])
  @@index([documentId])
}

model JournalLine {
  id                 String            @id @default(cuid())
  journalEntryId     String
  journalEntry       JournalEntry      @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  accountId          String
  account            LedgerAccount     @relation(fields: [accountId], references: [id], onDelete: Restrict)
  debitCents         Int               @default(0)
  creditCents        Int               @default(0)
  taxCode            String?
  taxPoint           DateTime?
  taxJurisdiction    String?
  netBaseCents       Int?
  taxRateBasisPoints Int?
  taxAmountCents     Int?
  deductibleTaxCents Int?
  taxRuleId          String?
  taxRuleVersion     Int?
  taxReason          String?
  vatPosting         VatPostingRecord?

  @@index([accountId])
}

model StructuredInvoice {
  id                 String         @id @default(cuid())
  ownerId            String
  documentId         String         @unique
  document           DocumentRecord @relation(fields: [documentId], references: [id], onDelete: Restrict)
  syntax             String
  kind               String
  direction          String
  issuerKey          String
  invoiceNumber      String
  issueDate          DateTime
  structuredHash     String
  visualHash         String?
  originalMediaType  String
  structuredOriginal Bytes
  visualOriginal     Bytes?
  data               String
  provenance         String
  renderedHtml       String
  correctsId         String?
  createdAt          DateTime       @default(now())

  @@unique([ownerId, direction, issuerKey, invoiceNumber])
  @@unique([ownerId, structuredHash])
  @@index([ownerId, issueDate])
  @@index([ownerId, correctsId])
}

model InvoiceNumberSequence {
  ownerId   String
  year      Int
  nextValue Int    @default(1)

  @@id([ownerId, year])
}

model InvoiceNumberReservation {
  id                  String   @id @default(cuid())
  ownerId             String
  year                Int
  sequenceValue       Int
  invoiceNumber       String
  status              String
  structuredInvoiceId String?
  failureReason       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([ownerId, year, sequenceValue])
  @@unique([ownerId, invoiceNumber])
  @@index([ownerId, status, createdAt])
}

model InvoiceIssuanceRequest {
  id                  String   @id @default(cuid())
  ownerId             String
  requestKey          String
  requestHash         String
  status              String   @default("PROCESSING")
  reservationId       String?
  storageKey          String?
  structuredInvoiceId String?
  error               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([ownerId, requestKey])
  @@index([ownerId, status, updatedAt])
}

model VatPostingRecord {
  id                 String       @id @default(cuid())
  ownerId            String
  sourceId           String
  journalLineId      String?      @unique
  journalLine        JournalLine? @relation(fields: [journalLineId], references: [id], onDelete: Restrict)
  documentId         String?
  taxPoint           DateTime
  jurisdiction       String
  netBaseCents       Int
  rateBasisPoints    Int
  taxCents           Int
  deductibleTaxCents Int
  grossCents         Int
  outputTaxCents     Int
  inputTaxCents      Int
  ruleId             String
  ruleVersion        Int
  vatCase            String
  reason             String
  returnBoxes        String
  source             String
  createdAt          DateTime     @default(now())

  @@unique([ownerId, sourceId])
  @@index([ownerId, taxPoint])
  @@index([ownerId, documentId])
}

model VatReversalMarker {
  ownerId   String
  marker    String
  createdAt DateTime @default(now())

  @@id([ownerId, marker])
}

model TaxWorkflowRecord {
  submissionId      String    @id
  ownerId           String
  kind              String
  period            String
  state             String
  revision          Int
  idempotencyKey    String
  payload           String
  receipt           String?
  correctsId        String?
  actionReservation String?
  deadline          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([ownerId, idempotencyKey])
  @@index([ownerId, kind, period, updatedAt])
  @@index([ownerId, correctsId])
}

model TaxSubmissionRequest {
  id           String   @id @default(cuid())
  ownerId      String
  requestKey   String
  datasetHash  String
  filingKey    String?  @unique
  status       String   @default("PROCESSING")
  submissionId String?
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([ownerId, requestKey])
  @@index([ownerId, createdAt])
}

model TaxAdjustmentRecord {
  id                String
  ownerId           String
  year              Int
  ruleVersion       String
  field             String
  layer             String
  amountCents       Int
  reason            String
  sourceDocumentIds String
  legalBasis        String
  treatment         String
  createdAt         DateTime @default(now())

  @@id([ownerId, id])
  @@index([ownerId, year])
}

model TaxDatasetPreparationRecord {
  id            String   @id @default(cuid())
  ownerId       String
  kind          String
  period        String
  datasetHash   String
  sourcePayload String?
  createdAt     DateTime @default(now())

  @@unique([ownerId, datasetHash])
  @@index([ownerId, kind, period, createdAt])
}

model TaxAssessmentRecord {
  id                      String
  ownerId                 String
  kind                    String
  period                  String
  assessedAmountCents     Int
  receivedAt              DateTime
  documentHash            String
  declarationSubmissionId String
  differenceCents         Int
  needsReview             Boolean
  createdAt               DateTime @default(now())

  @@id([ownerId, id])
  @@index([ownerId, kind, period])
  @@index([ownerId, declarationSubmissionId])
}

model User {
  id            String        @id
  name          String
  email         String        @unique
  emailVerified Boolean       @default(false)
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  accounts      AuthAccount[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model AuthAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

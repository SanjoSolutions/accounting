generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AccountRecord {
  id      String @id
  payload String
}

model DocumentRecord {
  id          String                      @id
  payload     String
  ownerId     String?
  attachments JournalDocumentAttachment[]

  @@index([ownerId])
}

model BookingRecordEntry {
  id      String @id
  payload String
}

model LedgerAccount {
  id              String        @id @default(cuid())
  ownerId         String
  number          Int
  name            String
  category        String
  eBilanzPosition String?
  active          Boolean       @default(true)
  journalLines    JournalLine[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([ownerId, number])
}

model LedgerProfile {
  ownerId          String  @id
  chart            String
  consultantNumber String?
  clientNumber     String?
  accountLength    Int?
}

model FiscalYear {
  id                  String               @id @default(cuid())
  ownerId             String
  year                Int
  startsAt            DateTime
  endsAt              DateTime
  status              String               @default("OPEN")
  lockedAt            DateTime?
  closingSnapshot     String?
  journalEntries      JournalEntry[]
  eBalanceSubmissions EBalanceSubmission[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([ownerId, year])
}

model EBalanceSubmission {
  id                String     @id @default(cuid())
  ownerId           String
  year              Int
  fiscalYearId      String
  fiscalYear        FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Restrict)
  kind              String
  status            String
  idempotencyKey    String
  payloadHash       String
  requestHash       String
  requestXml        String
  ericCode          Int?
  ericMessage       String?
  resultXml         String?
  serverResponseXml String?
  createdAt         DateTime   @default(now())

  @@unique([ownerId, idempotencyKey])
  @@index([ownerId, year, createdAt])
}

model JournalEntry {
  id             String        @id @default(cuid())
  sequenceNumber Int
  bookingDate    DateTime
  documentNumber String
  description    String
  source         String        @default("MANUAL")
  externalKey    String?       @unique
  fiscalYearId   String
  fiscalYear     FiscalYear    @relation(fields: [fiscalYearId], references: [id], onDelete: Restrict)
  lines          JournalLine[]
  documents      JournalDocumentAttachment[]
  createdAt      DateTime      @default(now())

  @@unique([fiscalYearId, sequenceNumber])
  @@unique([fiscalYearId, documentNumber])
  @@index([bookingDate])
}

model JournalDocumentAttachment {
  journalEntryId String
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  documentId     String
  document       DocumentRecord @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@id([journalEntryId, documentId])
  @@index([documentId])
}

model JournalLine {
  id             String        @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  accountId      String
  account        LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  debitCents     Int           @default(0)
  creditCents    Int           @default(0)
  taxCode        String?

  @@index([accountId])
}

model User {
  id            String        @id
  name          String
  email         String        @unique
  emailVerified Boolean       @default(false)
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  accounts      AuthAccount[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model AuthAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

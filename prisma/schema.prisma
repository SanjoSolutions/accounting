generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AccountRecord {
  id        String @id
  ownerId   String? @unique
  payload   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyProfileVersion {
  id String @id @default(cuid())
  ownerId String
  effectiveFrom DateTime
  effectiveTo DateTime?
  payload String
  createdBy String
  reason String
  createdAt DateTime @default(now())
  @@unique([ownerId, effectiveFrom])
  @@index([ownerId, effectiveFrom, effectiveTo])
}

model CompanyProfileAddressConfirmation {
  id String @id @default(cuid())
  ownerId String
  profileVersionId String @unique
  payload String
  createdBy String
  reason String
  createdAt DateTime @default(now())
  @@index([ownerId, createdAt])
}

model AuditEvent {
  id String @id
  ownerId String
  actorId String
  occurredAt DateTime
  action String
  reason String
  objectType String
  objectId String
  semanticDelta String
  previousHash String?
  hash String
  integrityKeyId String @default("default")
  createdAt DateTime @default(now())
  @@unique([ownerId, hash])
  @@index([ownerId, occurredAt])
}

model AuditHead {
  ownerId String @id
  headHash String?
  legacyHeadHash String?
  legacyEventCount Int @default(0)
  version Int @default(0)
  updatedAt DateTime @updatedAt
}

model BackupManifest {
  id String @id @default(cuid())
  ownerId String
  createdAt DateTime @default(now())
  databaseHash String
  objectStoreHash String
  encryptionKeyId String
  storageRegion String
  recoveryPointAt DateTime
  verifiedAt DateTime?
  restoredAt DateTime?
  manifest String
  payloadStorageKey String?
  status String @default("CREATED")
  @@index([ownerId, createdAt])
}

model CompliancePolicy {
  ownerId String @id
  allowedStorageRegions String
  operatorIds String
  recoveryPointObjectiveMinutes Int
  recoveryTimeObjectiveMinutes Int
  backupKeyId String
  updatedAt DateTime @updatedAt
}

model DocumentRecord {
  id          String                      @id
  payload     String
  ownerId     String?
  attachments JournalDocumentAttachment[]

  @@index([ownerId])
}

model DocumentStorageClaim {
  id         String   @id
  importId   String
  documentId String
  ownerId    String
  storageKey String
  createdStorage Boolean @default(false)
  createdAt  DateTime @default(now())

  @@unique([importId, documentId])
  @@index([documentId])
  @@index([createdAt])
}

model RetainedArtifact {
  id String @id @default(cuid())
  ownerId String
  objectType String
  objectId String
  version Int
  retentionClass String
  contentHash String
  provenance String
  storageKey String?
  periodEndsAt DateTime
  retainUntil DateTime
  legalHoldUntil DateTime?
  legalHoldReason String?
  lastFixityAt DateTime?
  disposedAt DateTime?
  disposalRequestedAt DateTime?
  storageDeletedAt DateTime?
  createdAt DateTime @default(now())
  @@unique([ownerId, objectType, objectId, version])
  @@index([ownerId, retainUntil, legalHoldUntil])
}

model FixityCheck {
  id String @id @default(cuid())
  ownerId String
  artifactId String
  expectedHash String
  actualHash String?
  status String
  readable Boolean
  checkedAt DateTime @default(now())
  @@index([ownerId, artifactId, checkedAt])
}

model BookingRecordEntry {
  id      String @id
  payload String
}

model LedgerAccount {
  id              String        @id @default(cuid())
  ownerId         String
  number          Int
  name            String
  category        String
  eBilanzPosition String?
  active          Boolean       @default(true)
  journalLines    JournalLine[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([ownerId, number])
}

model AccountMappingVersion {
  id String @id @default(cuid())
  ownerId String
  chartId String
  accountNumber Int
  effectiveFrom DateTime
  effectiveTo DateTime?
  accountName String
  accountType String
  normalBalance String
  hgbPosition String
  eBilanzPosition String
  vatCode String?
  active Boolean @default(true)
  createdAt DateTime @default(now())
  @@unique([ownerId, chartId, accountNumber, effectiveFrom])
  @@index([ownerId, effectiveFrom, effectiveTo])
}

model LedgerProfile {
  ownerId          String  @id
  chart            String
  consultantNumber String?
  clientNumber     String?
  accountLength    Int?
}

model FiscalYear {
  id                  String               @id @default(cuid())
  ownerId             String
  year                Int
  label               String?
  startsAt            DateTime
  endsAt              DateTime
  status              String               @default("OPEN")
  lockedAt            DateTime?
  closingSnapshot     String?
  journalEntries      JournalEntry[]
  eBalanceSubmissions EBalanceSubmission[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([ownerId, year])
  @@unique([ownerId, startsAt, endsAt])
  @@index([ownerId, startsAt, endsAt])
}

model EBalanceSubmission {
  id                String     @id @default(cuid())
  ownerId           String
  year              Int
  fiscalYearId      String
  fiscalYear        FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Restrict)
  kind              String
  status            String
  idempotencyKey    String
  payloadHash       String
  requestHash       String
  requestXml        String
  ericCode          Int?
  ericMessage       String?
  resultXml         String?
  serverResponseXml String?
  createdAt         DateTime   @default(now())

  @@unique([ownerId, idempotencyKey])
  @@index([ownerId, year, createdAt])
}

model JournalEntry {
  id             String        @id @default(cuid())
  sequenceNumber Int
  bookingDate    DateTime
  documentNumber String
  description    String
  source         String        @default("MANUAL")
  state          String        @default("POSTED")
  entryDate      DateTime?     @default(now())
  lateReason     String?
  reversalOfId   String?       @unique
  replacementOfId String?      @unique
  externalKey    String?       @unique
  fiscalYearId   String
  fiscalYear     FiscalYear    @relation(fields: [fiscalYearId], references: [id], onDelete: Restrict)
  lines          JournalLine[]
  documents      JournalDocumentAttachment[]
  createdAt      DateTime      @default(now())

  @@unique([fiscalYearId, sequenceNumber])
  @@unique([fiscalYearId, documentNumber])
  @@index([bookingDate])
}

model JournalDraft {
  id String @id @default(cuid())
  ownerId String
  fiscalYearId String
  payload String
  version Int @default(1)
  status String @default("DRAFT")
  postedEntryId String?
  createdBy String
  updatedBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([ownerId, fiscalYearId, status])
}

model PeriodReopenRequest {
  id String @id @default(cuid())
  ownerId String
  fiscalYearId String
  requestedBy String
  closeGenerationAt DateTime?
  approvedBy String?
  reason String
  status String
  requestedAt DateTime @default(now())
  decidedAt DateTime?
  @@index([ownerId, fiscalYearId, requestedAt])
}

model FilingAmendment {
  id String @id @default(cuid())
  ownerId String
  kind String
  originalObjectId String
  requestPayload String
  responsePayload String?
  receiptPayload String?
  reason String
  status String @default("DRAFT")
  createdBy String
  createdAt DateTime @default(now())
  @@index([ownerId, kind, originalObjectId, createdAt])
}

model JournalDocumentAttachment {
  journalEntryId String
  journalEntry   JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  documentId     String
  document       DocumentRecord @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@id([journalEntryId, documentId])
  @@index([documentId])
}

model JournalLine {
  id             String        @id @default(cuid())
  journalEntryId String
  journalEntry   JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  accountId      String
  account        LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  debitCents     Int           @default(0)
  creditCents    Int           @default(0)
  taxCode        String?

  @@index([accountId])
}

model User {
  id            String        @id
  name          String
  email         String        @unique
  emailVerified Boolean       @default(false)
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  accounts      AuthAccount[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model AuthAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
